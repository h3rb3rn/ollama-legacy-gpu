# ─────────────────────────────────────────────────────────────────────────────
# Ollama — RTX / GTX GPU instance                              Port 11434
# ─────────────────────────────────────────────────────────────────────────────
#
#   GPU pool (66 GB VRAM total):
#     3× RTX 2060  sm_7.5  Turing   12 GB  GDDR6  ~336 GB/s
#     2× RTX 3060  sm_8.6  Ampere   12 GB  GDDR6  ~360 GB/s
#     1× GTX 1060  sm_6.1  Pascal    6 GB  GDDR5  ~192 GB/s  ← overflow only
#
#   Primary model: llama4:scout (~34 GB weights, MoE 109B/17B active)
#     KV-cache at ctx=131072 × 3 parallel (q4_0): ~19 GB
#     Total GPU footprint: ~53 GB → fits in 66 GB with headroom
# ─────────────────────────────────────────────────────────────────────────────

OLLAMA_HOST=0.0.0.0

# Set default context to 131072 so llama4:scout is always warm at the right ctx.
# When num_ctx=131072 arrives per-request, Ollama reuses the running runner instead
# of tearing it down and triggering a GPU binary-search from scratch.
OLLAMA_CONTEXT_LENGTH=131072

# Keep models loaded between requests — especially important for a 34 GB model
# whose cold-load from NVMe takes 3–5 minutes.
OLLAMA_KEEP_ALIVE=60m

# Time Ollama waits for llama.cpp to finish loading all layers into VRAM.
# 34 GB over NVMe at ~2 GB/s → ~17 s minimum; 15 m gives ample headroom for
# GPU binary-search retries and CUDA context initialisation across 6 GPUs.
OLLAMA_LOAD_TIMEOUT=15m

# At ctx=131072 × 3 parallel, llama4:scout uses ~53 GB → leaves ~13 GB.
# A second large model would not fit; keep at 1 to prevent Ollama from splitting
# VRAM between two models when a second request for a different model arrives.
OLLAMA_MAX_LOADED_MODELS=1

# Three parallel inference slots: covers Planner + Judge + one Expert in
# simultaneous flight without triggering a runner reload.
OLLAMA_NUM_PARALLEL=3

# Spread the model across all 6 RTX/GTX GPUs so every layer stays on GPU.
# Without this, Ollama may pin layers to a single GPU and overflow to CPU.
OLLAMA_SCHED_SPREAD=true

# Flash Attention — enabled for Turing (sm_7.5) and Ampere (sm_8.6).
# llama.cpp silently disables FA on the GTX 1060 (sm_6.1) overflow GPU;
# no manual workaround needed.
OLLAMA_FLASH_ATTENTION=1

# q4_0 halves KV-cache VRAM vs. q8_0 and requires Flash Attention.
# At ctx=131072 × 3 parallel: q4_0 → ~19 GB, q8_0 → ~39 GB, f16 → ~77 GB (OOM).
# q4_0 is the only option that keeps llama4:scout fully on GPU at 128 k context.
OLLAMA_KV_CACHE_TYPE=q4_0

# Share KV prefix cache across concurrent users — off until workloads are confirmed
# to have identical system-prompt prefixes (otherwise wastes memory).
OLLAMA_MULTIUSER_CACHE=false

# Reserve 256 MB per GPU for CUDA context, driver, and peer-mapping overhead.
# 6 GPUs × 256 MB = 1.5 GB withheld from Ollama's VRAM budget.
# This prevents the GPU binary-search from over-committing and then failing at alloc.
OLLAMA_GPU_OVERHEAD=268435456

OLLAMA_METRICS=true
