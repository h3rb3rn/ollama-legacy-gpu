# ─────────────────────────────────────────────────────────────────────────────
# Ollama — N04-RTX combined GPU pool (all 12 GPUs, ~114 GB VRAM)
#
# GPU topology (auto-detected at startup by gpu-detect.sh):
#   3× RTX 2060  sm_7.5  12 GB each  = 36 GB
#   2× RTX 3060  sm_8.6  12 GB each  = 24 GB
#   1× GTX 1060  sm_6.1   6 GB       =  6 GB
#   2× Tesla M60 sm_5.2  ~8 GB each  = 16 GB
#   4× Tesla M10 sm_5.0   8 GB each  = 32 GB
#   Total:                            ~114 GB
#
# Dynamic pool (patch-ollama-dynamic-pool.py):
#   model <= 75% RTX fast pool (CC≥7.5):
#     → RTX-only CUDA_VISIBLE_DEVICES, FA=ON (MMA), KV=q4_0, np=2
#   model > threshold:
#     → all 12 GPUs, FA=ON (TILE for Tesla), KV=f16, np=1, split-mode=row
#
# Pipeline coordinator: always best GPU (CUDA nd-1 = RTX 3060, 360 GB/s)
#   via --main-gpu injected in selectGPUPool() — prevents Tesla M10 becoming
#   the coordinator (83 GB/s bottleneck causing 275% CPU usage on hybrid models)
# ─────────────────────────────────────────────────────────────────────────────

OLLAMA_HOST=0.0.0.0

# Global context length — per-pool overrides applied by selectGPUPool():
#   Fast Pool: up to OLLAMA_CONTEXT_LENGTH (RTX + q4_0 KV = headroom)
#   Full Pool: capped at OLLAMA_MAX_CTX_FULL_POOL (prevent 78 GB CPU buffer)
OLLAMA_CONTEXT_LENGTH=131072

# Keep models loaded between requests.
OLLAMA_KEEP_ALIVE=60m

# Allow 12 GPU endpoints + NVMe load time.
OLLAMA_LOAD_TIMEOUT=20m

# Two models simultaneously: qwen3.6:35b (~26 GB) + llama4:scout (~53 GB) = ~79 GB < 114 GB
OLLAMA_MAX_LOADED_MODELS=2

# H1: np=2 globally — selectGPUPool() reduces to np=1 for full pool via
# OLLAMA_MAX_BATCH_SIZE=64 → INLINE_BATCH_CAP → -np 2→1.
# Fast pool clears OLLAMA_MAX_BATCH_SIZE → np stays 2 (RTX has KV headroom).
OLLAMA_NUM_PARALLEL=2

# Spread each model across GPU endpoints for full VRAM utilization.
OLLAMA_SCHED_SPREAD=true

# H2: KV-cache type managed per pool by selectGPUPool():
#   Fast pool (RTX, FA=ON):  q4_0 → 4× smaller KV, enables np=2
#   Full pool (all 12 GPUs): f16  → safe for Tesla TILE-kernel
# No global override here — allow selectGPUPool() to control per load.

# Fallback overhead scale until auto-optimizer has run.
OLLAMA_LAYER_OVERHEAD_SCALE=1.4

# Reserve 256 MB per GPU endpoint for CUDA context and driver overhead.
OLLAMA_GPU_OVERHEAD=268435456

# Auto-detect GPU topology at startup via NVML.
OLLAMA_GPU_AUTODETECT=1

# Pre-optimize primary model at startup.
OLLAMA_PRIMARY_MODEL=qwen3.6:35b
OLLAMA_AUTO_OPTIMIZE=1

# H8: Auto-optimizer skips models larger than this threshold (long load times).
# Full-pool models (>50 GB) run scale-only pass, no MTP optimization.
OLLAMA_SKIP_OPTIMIZE_SIZE_GB=50

# Inline batch cap for full pool — selectGPUPool() sets this for large models.
# Fast pool clears it (np=2 stays); full pool sets it (np reduced to 1).
OLLAMA_MAX_BATCH_SIZE=64

# H3: Split mode for full pool (large/hybrid models).
# 'row' = tensor parallelism (all GPUs compute each layer in parallel).
# 'layer' = pipeline parallelism (sequential, single GPU active at a time).
# Override per model via OLLAMA_SPLIT_MODE env — selectGPUPool() sets default.
# Set to 'layer' here to globally disable row split if needed.
# OLLAMA_SPLIT_MODE=layer

# H6: Max context for full pool to prevent 78 GB CPU buffer on hybrid models.
# qwen3.6-40b-neo with 204800 ctx → 78 GB CUDA_Host buffer → 275% CPU.
# 65536 keeps CPU buffer manageable (~20 GB) while covering most use cases.
OLLAMA_MAX_CTX_FULL_POOL=65536

OLLAMA_METRICS=true
OLLAMA_CUDA_REVERSED=GPU-63bfbd4b-9dd7-75ee-e025-d7c8966fcc42,GPU-6e62055a-46d4-e5e1-41d6-90efc6aa3dbb,GPU-fb5f0ecf-b19c-6899-c507-215130ede1a6,GPU-6cf8a010-9ab8-f640-b5d4-b88540b220b7,GPU-ed954d67-584b-f101-ae1e-5cd4df31cebc,GPU-04dd9215-d446-8bf1-1010-0f61530f1770,GPU-2dc77b8a-fb51-6cfa-fd0c-2bb951f55b98,GPU-d34095b6-ff1d-6abb-9605-94a1b120f7b3,GPU-113fd30d-cb6f-ad02-0803-2c2b9053709d,GPU-7b3bd39b-b948-09a6-8ef9-756406efdb99,GPU-086bd19b-5a4c-a6dc-8c82-9c1a5276b0b2,GPU-f668b685-3c6d-0fc7-1f85-960a0607c561
