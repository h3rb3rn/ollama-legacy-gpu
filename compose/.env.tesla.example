# ─────────────────────────────────────────────────────────────────────────────
# Ollama — Tesla M10 / M60 GPU instance                        Port 11435
# ─────────────────────────────────────────────────────────────────────────────
#
#   GPU pool (32 GB VRAM total):
#     4× Tesla M10  sm_5.0  Maxwell   8 GB  GDDR5  ~166 GB/s
#   (Tesla M60 excluded — heterogeneous M10+M60 pool causes ggml_gallocr OOM;
#    M60 7.5 GB is smaller than the 8.98 GB contiguous compute-graph block ggml
#    requires per device. Homogeneous M10-only pool matches N11-M10 which runs
#    qwen3.6:35b successfully at 32 GB.)
#
#   Primary model: qwen3.6:35b (Q4_K_M, ~20 GB weights, Hybrid SSM/Attention MoE)
#     Architecture: 40 layers total — only 10 are Attention layers (every 4th);
#     the remaining 30 are SSM layers with no KV-cache. 2 KV heads per Attention
#     layer, key_length=256 + value_length=256.
#     KV-cache formula: 10 layers × 2 KV-heads × 512 dim × ctx × parallel × 2 bytes
#     At ctx=200000 × 2 parallel (f16): 10×2×512×200000×2×2 / 1e9 ≈ 16.4 GB
#     Total GPU footprint: ~20 GB (weights) + ~16.4 GB (KV) ≈ 36.7 GB → fits in 47 GB ✓
#
#   Note: Flash Attention requires sm_7.5+ (Turing). Maxwell GPUs do not support
#   it. Running FA=1 on Maxwell causes llama.cpp to fall back silently, but using
#   q4_0 / q8_0 KV-cache without FA produces incorrect results in some versions.
#   f16 KV-cache is the only guaranteed-correct option on Maxwell.
# ─────────────────────────────────────────────────────────────────────────────

# Listen on port 11435; primary port 11434 is taken by the RTX instance.
OLLAMA_HOST=0.0.0.0:11435

# qwen3.6:35b is a hybrid SSM/Attention MoE with 256 experts (8 active per token).
# The 256-expert MoE routing creates compute buffers that ggml tries to allocate
# as one contiguous CUDA block per GPU. At BatchSize=512 this block reaches 27+ GB —
# impossible to fit on 7.5–8 GB Tesla cards.
# Reducing context to 65536 does NOT fix this — the compute buffer is context-
# independent. Reducing context only helps if OLLAMA_BATCH_SIZE is also lowered.
# 65536 is a reasonable default that Ollama's binary-search will survive, and the
# actual usable context is determined by what the alloc phase can commit.
OLLAMA_CONTEXT_LENGTH=65536

# Shorter keep-alive than RTX: at ~22 GB, qwen3.6:35b reloads in ~10 s from
# a warm NVMe page cache, so eviction cost is low.
OLLAMA_KEEP_ALIVE=30m

# 22 GB model over NVMe plus CUDA init across 6 Tesla GPUs.
OLLAMA_LOAD_TIMEOUT=10m

# Two mid-size models (~22 GB each) can coexist at 47 GB if context is small.
# Allows a second model for tool-use or fallback without evicting the primary.
OLLAMA_MAX_LOADED_MODELS=2

# Two parallel inference slots. Maxwell's lower bandwidth (~160–166 GB/s vs
# ~360 GB/s on RTX) means 3 parallel slots would thrash bandwidth and increase
# per-token latency rather than improve overall throughput.
OLLAMA_NUM_PARALLEL=2

# Spread qwen3.6:35b across all 6 Tesla GPUs to maximise aggregate bandwidth
# (~960 GB/s combined vs. 160 GB/s on a single M10).
OLLAMA_SCHED_SPREAD=true

# Maxwell (sm_5.0 / sm_5.2) does not support Flash Attention.
OLLAMA_FLASH_ATTENTION=0

# f16: the only safe KV-cache format without Flash Attention.
# q4_0 / q8_0 quantised KV-cache paths in llama.cpp use FA-specific kernels
# and must not be used on pre-Turing hardware.
OLLAMA_KV_CACHE_TYPE=f16

OLLAMA_MULTIUSER_CACHE=false

# Reserve 128 MB per GPU for CUDA overhead on Maxwell.
# 6 GPUs × 128 MB = 768 MB withheld from Ollama's VRAM budget.
OLLAMA_GPU_OVERHEAD=134217728

OLLAMA_METRICS=true
