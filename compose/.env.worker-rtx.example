# ─────────────────────────────────────────────────────────────────────────────
# Ollama — Kombinierter GPU-Pool (alle 12 GPU-Endpoints)       Port 11434
# ─────────────────────────────────────────────────────────────────────────────
#
#   GPU 0-3,6:   5× RTX (2×RTX2060 sm_7.5 + 3×RTX3060 sm_8.6)  60 GB
#   GPU 4-5:     Tesla M60 (2 GPU-Dies, sm_5.2)                   15 GB
#   GPU 7-10:    Tesla M10 (4 GPU-Dies, sm_5.2)                   32 GB
#   GPU 11:      GTX 1060 (sm_6.1)                                 6 GB
#   Gesamt:                                                       ~114 GB
#
#   Primärmodell: llama4:scout (~34 GB weights)
#     ctx=131072 × 4 parallel (f16): ~26 GB KV-Cache
#     Gesamt: ~60 GB → 54 GB Headroom für zweites Modell
# ─────────────────────────────────────────────────────────────────────────────

OLLAMA_HOST=0.0.0.0

# 131072 damit llama4:scout warm bleibt und nicht neu geladen wird.
OLLAMA_CONTEXT_LENGTH=131072

OLLAMA_KEEP_ALIVE=60m

# NVMe + 12 GPU CUDA-Inits brauchen Puffer.
OLLAMA_LOAD_TIMEOUT=20m

# Zwei Modelle passen bei 114 GB locker gleichzeitig (z.B. llama4:scout + qwen3.6:35b).
OLLAMA_MAX_LOADED_MODELS=2

# Vier parallele Slots: Planner + Judge + 2 Experten gleichzeitig.
OLLAMA_NUM_PARALLEL=4

# Verteile jedes Modell über alle GPU-Endpoints.
OLLAMA_SCHED_SPREAD=true

# Flash Attention MUSS deaktiviert sein: Tesla M10/M60 (sm_5.2) unterstützen FA nicht.
# RTX-GPUs könnten FA nutzen, aber im gemischten Pool muss FA global aus sein.
OLLAMA_FLASH_ATTENTION=0

# f16: einzig korrekte KV-Cache-Option ohne Flash Attention auf Maxwell-GPUs.
OLLAMA_KV_CACHE_TYPE=f16

OLLAMA_MULTIUSER_CACHE=false

# 256 MB Overhead × 12 GPU-Endpoints = 3 GB Puffer.
OLLAMA_GPU_OVERHEAD=268435456

# PTX-JIT-Kernel für Tesla M10/M60 werden hier gecacht.
CUDA_CACHE_PATH=/root/.ollama/cuda-cache

OLLAMA_METRICS=true
