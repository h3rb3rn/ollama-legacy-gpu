# ─────────────────────────────────────────────────────────────────────────────
# Ollama — Combined GPU pool (all 12 GPU endpoints)            Port 11434
# ─────────────────────────────────────────────────────────────────────────────
#
#   GPU 0-3,6:   5× RTX (2×RTX2060 sm_7.5 + 3×RTX3060 sm_8.6)  60 GB
#   GPU 4-5:     Tesla M60 (2 GPU dies, sm_5.2)                   15 GB
#   GPU 7-10:    Tesla M10 (4 GPU dies, sm_5.0)                   32 GB
#   GPU 11:      GTX 1060 (sm_6.1)                                 6 GB
#   Total:                                                        ~114 GB
#
#   Primary model: llama4:scout (~34 GB weights)
#     ctx=131072 × 4 parallel (f16): ~26 GB KV-cache
#     Total: ~60 GB → 54 GB headroom for a second model
# ─────────────────────────────────────────────────────────────────────────────

OLLAMA_HOST=0.0.0.0

# Keep llama4:scout warm at the right context size.
OLLAMA_CONTEXT_LENGTH=131072

OLLAMA_KEEP_ALIVE=60m

# NVMe + 12 GPU CUDA inits need extra time to settle.
OLLAMA_LOAD_TIMEOUT=20m

# Two models fit comfortably at 114 GB (e.g. llama4:scout + qwen3.6:35b).
OLLAMA_MAX_LOADED_MODELS=2

# Four parallel slots: Planner + Judge + 2 Experts simultaneously.
OLLAMA_NUM_PARALLEL=4

# Spread each model across all GPU endpoints.
OLLAMA_SCHED_SPREAD=true

# Flash Attention MUST be disabled: Tesla M10/M60 (sm_5.0/5.2) do not support FA.
# RTX GPUs could use FA, but in a mixed pool FA must be off globally.
OLLAMA_FLASH_ATTENTION=0

# f16: the only correct KV-cache option without Flash Attention on Maxwell GPUs.
OLLAMA_KV_CACHE_TYPE=f16

OLLAMA_MULTIUSER_CACHE=false

# 256 MB overhead × 12 GPU endpoints = 3 GB reserved.
OLLAMA_GPU_OVERHEAD=268435456

# PTX-JIT kernels for Tesla M10/M60 are cached here.
CUDA_CACHE_PATH=/root/.ollama/cuda-cache

OLLAMA_METRICS=true
