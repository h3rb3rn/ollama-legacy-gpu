# ─────────────────────────────────────────────────────────────────────────────
# Ollama — Kombinierter GPU-Pool (RTX + Tesla M10)              Port 11434
# ─────────────────────────────────────────────────────────────────────────────
#
#   GPU-Pool (98 GB VRAM gesamt):
#     3× RTX 2060  sm_7.5  Turing   12 GB  GDDR6  ~336 GB/s
#     2× RTX 3060  sm_8.6  Ampere   12 GB  GDDR6  ~360 GB/s
#     1× GTX 1060  sm_6.1  Pascal    6 GB  GDDR5  ~192 GB/s
#     4× Tesla M10 sm_5.2  Maxwell   8 GB  GDDR5  ~160 GB/s  (PTX-JIT)
#
#   Primärmodell: llama4:scout (~34 GB weights, MoE 109B/17B active)
#     Mit 98 GB statt 66 GB: KV-Cache bei ctx=131072 × 4 parallel (f16): ~26 GB
#     Gesamter GPU-Footprint: ~60 GB → 38 GB Headroom für zweites Modell
#
#   Zweites Modell: qwen3.6:35b (~20 GB weights)
#     Gesamte kombinierte Belegung: ~80 GB → passt in 98 GB ✓
# ─────────────────────────────────────────────────────────────────────────────

OLLAMA_HOST=0.0.0.0

# 131072 damit llama4:scout immer warm ist und nicht neu geladen wird.
OLLAMA_CONTEXT_LENGTH=131072

OLLAMA_KEEP_ALIVE=60m

# 34 GB Model über NVMe; 10 GPUs brauchen länger für CUDA-Init.
OLLAMA_LOAD_TIMEOUT=20m

# Zwei Modelle können bei 98 GB koexistieren (z.B. llama4:scout + qwen3.6:35b).
OLLAMA_MAX_LOADED_MODELS=2

# Vier parallele Slots: Planner + Judge + 2 Experten gleichzeitig möglich.
OLLAMA_NUM_PARALLEL=4

# Verteile jedes Modell über alle 10 GPUs für maximale Aggregat-Bandbreite.
OLLAMA_SCHED_SPREAD=true

# Flash Attention MUSS deaktiviert sein: Tesla M10 (sm_5.2) unterstützt FA nicht.
# llama.cpp würde FA auf Maxwell stumm deaktivieren, aber q4_0/q8_0 KV-Cache
# setzt FA-spezifische Kernel voraus → falsche Ergebnisse ohne FA.
OLLAMA_FLASH_ATTENTION=0

# f16: einzig korrekte KV-Cache-Option ohne Flash Attention.
# Bei 98 GB VRAM ist f16 (statt q4_0/q8_0) tragbar: llama4:scout bei
# ctx=131072 × 4 parallel benötigt ~26 GB KV → gesamt ~60 GB.
OLLAMA_KV_CACHE_TYPE=f16

OLLAMA_MULTIUSER_CACHE=false

# 256 MB Overhead pro GPU × 10 GPUs = 2.5 GB Puffer für CUDA-Context + Treiber.
OLLAMA_GPU_OVERHEAD=268435456

OLLAMA_METRICS=true
