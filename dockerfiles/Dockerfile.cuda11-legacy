# dockerfiles/Dockerfile.cuda11-legacy
#
# Ollama für Tesla K80 (CC 3.7, Kepler) + Tesla M10/M60 (CC 5.2, Maxwell)
# CUDA 11.8 — letzte CUDA-Version mit offizieller CC 3.7 Unterstützung
#
# Da Ollama ab v0.30.x keinen CUDA-11-Preset mehr hat, injiziert dieses Dockerfile
# unsere eigenen Presets aus presets/cuda11-presets.json in den Ollama-Source-Tree.
# Die Injektion ist nicht-destruktiv: bestehende Presets bleiben erhalten.
#
# PTX-JIT Hinweis: 37-virtual;50-virtual;52-virtual → Kernel werden beim ersten
# Modell-Load auf der GPU JIT-kompiliert (~5s), danach gecacht.
#
# Build:
#   docker build -f dockerfiles/Dockerfile.cuda11-legacy \
#     --build-arg OLLAMA_VERSION=v0.9.0 \
#     --build-arg JOBS=8 \
#     -t ghcr.io/<owner>/ollama-legacy:cuda11-legacy-v0.9.0 .

ARG CUDA11_VERSION=11.8.0

# ── Stage 1: Build-Toolchain ──────────────────────────────────────────────────
FROM nvidia/cuda:${CUDA11_VERSION}-devel-ubuntu20.04 AS builder

ARG OLLAMA_VERSION=main
ARG CUDA_ARCHITECTURES="37-virtual;50-virtual;52-virtual;60-virtual;61-virtual;70-virtual;75-virtual;80-virtual"
ARG JOBS=8

ENV DEBIAN_FRONTEND=noninteractive
ENV CMAKE_GENERATOR=Ninja

# CMake 3.31+ und Ninja aus Source — Ubuntu 20.04 apt hat zu alte Versionen
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential git curl ca-certificates python3 ninja-build \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL https://github.com/Kitware/CMake/releases/download/v3.31.7/cmake-3.31.7-linux-x86_64.tar.gz \
       | tar -C /usr/local --strip-components=1 -xz

WORKDIR /src
RUN git clone --depth=1 \
    $([ "${OLLAMA_VERSION}" != "main" ] && echo "--branch ${OLLAMA_VERSION}") \
    https://github.com/ollama/ollama.git . \
    && echo "Ollama $(git rev-parse --short HEAD) / $(cat LLAMA_CPP_VERSION)"

# Go — Version aus go.mod lesen
RUN GO_VER=$(awk '/^go / { print $2 }' go.mod) \
    && curl -fsSL "https://go.dev/dl/go${GO_VER}.linux-amd64.tar.gz" \
       | tar -C /usr/local -xz
ENV PATH="/usr/local/go/bin:/usr/local/cuda/bin:$PATH"

# CUDA 11 Preset injizieren (fügt llama_cuda_v11_linux zu llama/server/CMakePresets.json hinzu)
COPY presets/cuda11-presets.json /tmp/cuda11-presets.json
COPY scripts/inject-presets.py   /tmp/inject-presets.py
RUN python3 /tmp/inject-presets.py \
    --source  /src \
    --presets /tmp/cuda11-presets.json

# CUDA v11 Runner bauen mit unserem injizierten Preset
RUN --mount=type=cache,target=/root/.ccache \
    cmake -S llama/server \
          --preset llama_cuda_v11_linux \
          -DCMAKE_CUDA_ARCHITECTURES="${CUDA_ARCHITECTURES}" \
    && cmake --build build/llama-server-cuda_v11 \
             --parallel "${JOBS}" \
    && cmake --install build/llama-server-cuda_v11 \
             --component llama-server \
             --strip

# Go-Binary
RUN --mount=type=cache,target=/root/.cache/go-build \
    go build -trimpath -buildmode=pie -ldflags="-w -s" -o /bin/ollama .

# ── Stage 2: Runtime ──────────────────────────────────────────────────────────
FROM ubuntu:22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl libvulkan1 libopenblas0 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /bin/ollama          /usr/bin/ollama
COPY --from=builder /src/dist/lib/ollama /usr/lib/ollama

ENV LD_LIBRARY_PATH=/usr/local/nvidia/lib:/usr/local/nvidia/lib64
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility
ENV NVIDIA_VISIBLE_DEVICES=all
ENV OLLAMA_HOST=0.0.0.0:11434

EXPOSE 11434
VOLUME ["/root/.ollama"]

HEALTHCHECK --interval=30s --timeout=15s --retries=5 --start-period=90s \
    CMD curl -sf http://localhost:11434/api/tags || exit 1

ENTRYPOINT ["/usr/bin/ollama"]
CMD ["serve"]
