# dockerfiles/Dockerfile.cuda12-maxwell
#
# Ollama for Tesla M10 / M60 (Compute Capability 5.0/5.2, Maxwell)
# CUDA 12.0.1 — lowest CUDA 12 release, broadest M10/M60 driver compatibility
#
# Using CUDA 12.0.1 instead of 12.5/12.8 so older drivers remain compatible.
# GGML_CUDA_FA=OFF: Flash Attention requires CC >= 8.0.
#
# IMPORTANT — -real instead of -virtual for Maxwell (CC 5.0/5.2):
#   -virtual targets generate PTX (intermediate code) that the CUDA driver
#   JIT-compiles to native SASS at first model load. On Maxwell with 12 GPUs
#   this causes a ~25-minute cold-start penalty (JIT per GPU per fitting iteration).
#   -real targets embed native CUBIN directly — no JIT, instant startup.
#   Insight from github.com/dogkeeper886/ollama37 (ollama37 K80 fork).
#
# Build:
#   docker build -f dockerfiles/Dockerfile.cuda12-maxwell \
#     --build-arg OLLAMA_VERSION=v0.9.0 \
#     --build-arg JOBS=8 \
#     -t ghcr.io/<owner>/ollama-legacy:cuda12-maxwell-v0.9.0 .
#
# Optional build args:
#   CUDA_ARCHITECTURES  NVCC target list (default: Maxwell + all newer up to Blackwell)
#   JOBS                Parallel build jobs

ARG CUDA12_VERSION=12.0.1
ARG CMAKE_VERSION=3.31.7
# Optional: use a custom llama.cpp fork instead of the version bundled with Ollama.
# Set to "https://github.com/h3rb3rn/llama.cpp-legacy-gpu.git" to use our fork
# with native greedy fill + bandwidth-weighted budgets (no Python patches needed).
# Set to "" (empty) to use Ollama's bundled llama.cpp version (default).
ARG LLAMA_CPP_FORK=""
ARG LLAMA_CPP_BRANCH="legacy-gpu-support"

# ── Stage 1: Build toolchain ──────────────────────────────────────────────────
FROM nvidia/cuda:${CUDA12_VERSION}-devel-ubuntu22.04 AS builder

ARG OLLAMA_VERSION=main
ARG CUDA_ARCHITECTURES="50-real;52-real;60-real;61-real;70-real;75-real;80-real;86-real;89-real;90-real"
ARG JOBS=8
ARG CMAKE_VERSION=3.31.7

ENV DEBIAN_FRONTEND=noninteractive
ENV CMAKE_GENERATOR=Ninja

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential git curl ca-certificates ninja-build ccache python3 \
    && rm -rf /var/lib/apt/lists/*

# CMake >= 3.24 required — Ubuntu 22.04 apt only ships 3.22
RUN curl -fsSL "https://github.com/Kitware/CMake/releases/download/v${CMAKE_VERSION}/cmake-${CMAKE_VERSION}-linux-x86_64.tar.gz" \
    | tar -C /usr/local --strip-components=1 -xz

COPY scripts/patch-llama-tier-fitting.py /tmp/patch-llama-tier-fitting.py
COPY scripts/patch-ollama-fa.py           /tmp/patch-ollama-fa.py
COPY scripts/patch-ollama-dynamic-pool.py /tmp/patch-ollama-dynamic-pool.py
COPY scripts/patch-ollama-batch.py        /tmp/patch-ollama-batch.py

WORKDIR /src
RUN git clone --depth=1 \
    $([ "${OLLAMA_VERSION}" != "main" ] && echo "--branch ${OLLAMA_VERSION}") \
    https://github.com/ollama/ollama.git . \
    && echo "Ollama $(git rev-parse --short HEAD) / $(cat LLAMA_CPP_VERSION)"

# Go — read version from go.mod
RUN GO_VER=$(awk '/^go / { print $2 }' go.mod) \
    && curl -fsSL "https://go.dev/dl/go${GO_VER}.linux-amd64.tar.gz" \
       | tar -C /usr/local -xz
ENV PATH="/usr/local/go/bin:/usr/local/cuda/bin:$PATH"

# Step 1: cmake configure — fetches llama.cpp via FetchContent to _deps/llama_cpp-src/
# If LLAMA_CPP_FORK is set, override the bundled version with our fork.
# Separated from build so patches can be applied in between.
RUN cmake -S llama/server \
          --preset llama_cuda_v12_linux \
          -DCMAKE_CUDA_ARCHITECTURES="${CUDA_ARCHITECTURES}" \
          -DGGML_CUDA_FA=OFF \
    && if [ -n "${LLAMA_CPP_FORK}" ]; then \
        echo "Using custom llama.cpp fork: ${LLAMA_CPP_FORK}"; \
        LLAMA_SRC="build/llama-server-cuda_v12/_deps/llama_cpp-src"; \
        rm -rf "$LLAMA_SRC"; \
        git clone --depth=1 --branch "${LLAMA_CPP_BRANCH}" "${LLAMA_CPP_FORK}" "$LLAMA_SRC"; \
        echo "Fork: $(git -C $LLAMA_SRC rev-parse --short HEAD)"; \
    fi

# Step 2: GPU-tier-fitting patch — applies Python patches to common/fit.cpp.
# When LLAMA_CPP_FORK is used, the fork already has these patches natively
# so this step is a no-op (the patch guard prevents double-patching).
RUN python3 /tmp/patch-llama-tier-fitting.py /src

# Step 3: cmake build + install
# NOTE: No --component filter → installs llama-server binary + CUDA libs.
# --component llama-server only installs .so files, not the binary itself.
RUN --mount=type=cache,id=ollama-ccache,target=/root/.ccache \
    cmake --build build/llama-server-cuda_v12 \
          --parallel "${JOBS}" \
    && cmake --install build/llama-server-cuda_v12 \
             --strip

# Collect all runtime files into /runtime:
#   cmake installs llama-server to dist/bin/ (not dist/lib/ollama/).
#   The Ollama Go binary searches for llama-server at /usr/lib/ollama/llama-server.
#   All shared libs are required because RPATH=$ORIGIN → /usr/lib/ollama/.
#   libllama-server-impl.so and libllama-quantize-impl.so are built but not
#   installed by cmake — must be copied manually from the build directory.
#   libnccl is linked by libggml-cuda.so and must come from the builder image.
RUN mkdir -p /runtime \
    && cp -aT /src/dist/lib/ollama /runtime \
    && find /src/dist/lib -maxdepth 1 -name 'lib*.so*' -exec cp -P {} /runtime/ \; \
    && find /src/build/llama-server-cuda_v12/bin -maxdepth 1 \( -type f -o -type l \) \
       -exec cp -P {} /runtime/ \; \
    && find /usr/lib/x86_64-linux-gnu -maxdepth 1 -name 'libnccl.so*' -exec cp -P {} /runtime/cuda_v12/ \; 2>/dev/null || true \
    && ls -lh /runtime/ /runtime/cuda_v12/

# Go patches — applied before go build:
# 1. Tier-aware FA: enable FA when model uses only fast GPUs (CC >= 7.0)
RUN python3 /tmp/patch-ollama-fa.py /src
# 2. Dynamic GPU pool: per-model CUDA_VISIBLE_DEVICES selection based on model size
#    Small models (fits in FAST_POOL_VRAM_GB): use fast GPUs only (FA=ON)
#    Large models: use all GPUs (FA=OFF, full Tesla pool)
RUN python3 /tmp/patch-ollama-dynamic-pool.py /src
# 3. Batch size cap: OLLAMA_MAX_BATCH_SIZE limits numBatch/numUBatch.
#    Reduces prefill compute buffer (batch × ctx × heads × 4 bytes) so Tesla
#    GPUs can participate in multi-GPU inference without OOM.
RUN python3 /tmp/patch-ollama-batch.py /src

# Go binary
RUN --mount=type=cache,target=/root/.cache/go-build \
    go build -trimpath -buildmode=pie -ldflags="-w -s" -o /bin/ollama .

# ── Stage 2: Runtime ──────────────────────────────────────────────────────────
FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl libvulkan1 libopenblas0 python3 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /bin/ollama  /usr/bin/ollama
COPY --from=builder /runtime     /usr/lib/ollama

# GPU auto-detection, tier-fitting entrypoint, auto-optimizer and proxy
COPY scripts/gpu-detect.sh         /usr/local/bin/gpu-detect.sh
COPY scripts/ollama-entrypoint.sh  /usr/local/bin/ollama-entrypoint.sh
COPY scripts/auto-optimize.py      /usr/local/bin/auto-optimize.py
COPY scripts/ollama-proxy.py       /usr/local/bin/ollama-proxy.py
RUN chmod +x /usr/local/bin/gpu-detect.sh /usr/local/bin/ollama-entrypoint.sh \
    && chmod +x /usr/local/bin/auto-optimize.py /usr/local/bin/ollama-proxy.py

# /usr/lib/ollama must be first so libggml-base.so.0 is found when libggml-cuda.so
# (RPATH=$ORIGIN pointing to cuda_v12/) falls back to LD_LIBRARY_PATH.
ENV LD_LIBRARY_PATH=/usr/lib/ollama:/usr/local/nvidia/lib:/usr/local/nvidia/lib64
ENV NVIDIA_DRIVER_CAPABILITIES=compute,utility
ENV NVIDIA_VISIBLE_DEVICES=all
ENV OLLAMA_HOST=0.0.0.0:11434

EXPOSE 11434
VOLUME ["/root/.ollama"]

HEALTHCHECK --interval=30s --timeout=15s --retries=5 --start-period=90s \
    CMD curl -sf http://localhost:11434/api/tags || exit 1

ENTRYPOINT ["/usr/local/bin/ollama-entrypoint.sh"]
CMD ["serve"]
