{
  "configurePresets": [
    {
      "name": "llama_cuda_v11_base",
      "hidden": true,
      "inherits": ["default"],
      "cacheVariables": {
        "GGML_CUDA": "ON",
        "CMAKE_CUDA_FLAGS": "-Wno-deprecated-gpu-targets -t 2",
        "OLLAMA_RUNNER_DIR": "cuda_v11",
        "OLLAMA_GPU_BACKEND": "cuda",
        "GGML_CUDA_FA": "OFF"
      }
    },
    {
      "name": "llama_cuda_v11_linux",
      "inherits": ["llama_cuda_v11_base"],
      "binaryDir": "${sourceDir}/../../build/llama-server-cuda_v11",
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "37-virtual;50-virtual;52-virtual;60-virtual;61-virtual;70-virtual;75-virtual;80-virtual"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "llama_cuda_v11_linux",
      "configurePreset": "llama_cuda_v11_linux",
      "targets": ["ggml-cuda"]
    }
  ]
}
